generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid()) 
  email     String   @unique             
  password  String                        
  createdAt DateTime @default(now())      
}

model Project {
  id          String   @id @default(cuid())
  title       String
  titleEN    String?
  category    String
  description String
  descriptionEN String?
  imageUrl    String?  
  repoUrl     String?  
  liveUrl     String?  
  tags        String[] 
  featured    Boolean  @default(false) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  views       View[]
  likes       Like[]
}

model View {
  id        String   @id @default(cuid())
  sessionId String  
  createdAt DateTime @default(now())

  
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String   

  @@unique([sessionId, projectId]) 
}

model Like {
  id        String   @id @default(cuid())
  sessionId String  
  createdAt DateTime @default(now())

 
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

 
  @@unique([sessionId, projectId]) 
}